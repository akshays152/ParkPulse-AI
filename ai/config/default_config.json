{
  "model_path": "yolo11n.pt",
  "confidence_threshold": 0.35,
  "iou_threshold": 0.5,
  "tracker_config": "ai/config/bytetrack_parkpulse.yaml",
  "image_size": 640,
  "max_detections": 80,
  "device": null,
  "use_half_precision": false,
  "use_model_fusion": true,
  "no_parking_zone": [[100, 120], [500, 120], [500, 450], [100, 450]],
  "parking_anchor": "bottom_center",
  "illegal_parking_seconds": 20.0,
  "road_importance": 2,
  "nearby_distance_pixels": 120.0,
  "max_duration_for_score": 120.0,
  "max_nearby_vehicles_for_score": 10,
  "low_priority_max_score": 30,
  "medium_priority_max_score": 70,
  "stale_track_frames": 30,
  "default_fps": 30.0,
  "default_output_video": "outputs/annotated_output.mp4",
  "default_output_json": "outputs/illegal_parking_events.json",
  "default_output_csv": "outputs/illegal_parking_events.csv",
  "screenshot_dir": "outputs/violation_screenshots",
  "heatmap_output_path": "outputs/parking_hotspots_heatmap.jpg",
  "log_level": "INFO",
  "log_file": "outputs/parkpulse_ai.log",
  "save_violation_screenshots": true,
  "heatmap_enabled": true,
  "heatmap_alpha": 0.45,
  "heatmap_radius": 32,
  "heatmap_decay": 0.995,
  "smoothing_enabled": true,
  "smoothing_alpha": 0.65,
  "process_every_n_frames": 1
}
